{
  "env": "gc",
  "debug": true,
  "print_level": "info",
  "arrival_timeout": "100",
  "prometheus_pushgateway": "",
  "print_logpath": "/home/admin/log",
  "config_path":"../config/json/",
  "slg_map_data":"../config/mapRes_0.json",
  "cluster": {
    "discovery": {
      "mode": "nats",
      "@mode1": "mode=default,从profile-{x}.json读取node节点的配置数据",
      "@mode2": "mode=nats,通过nats->master_node_id获取已注册的节点",
      "@mode3": "mode=etcd,通过etcd同步已注册节点"
    },
    "nats": {
      "master_node_id": "262145",
      "address": "nats://127.0.0.1:4222",
      "reconnect_delay": 5,
      "max_reconnects": -1,
      "request_timeout": 2,
      "user": "actorgo",
      "password": "actorgo2026"
    },
    "etcd": {
      "end_points": "127.0.0.1:2379",
      "@end_points": "dev.com:2379,dev1.com:2379",
      "prefix": "/actorgo",
      "ttl": 5,
      "dial_timeout": 3,
      "dial_keep_alive_time": 1,
      "dial_keep_alive_timeout": 1,
      "user": "actorgo",
      "password": "actorgo2026"
    }
  },
  "node": {
    "1": [
      {
        "address": "",
        "__settings__": {
          "node_name": "mastersvr",
          "ref_logger": "mastersvr_log"
        },
        "enable": true
      }
    ],
    "2": [
      {
        "address": "",
        "__settings__": {
          "node_name": "loginserver",
          "ref_logger": "loginserver_log",
          "mongo_id_list":{
            "slg_db":"slg_db"
          }
        },
        "enable": true
      }
    ],
    "3": [
      {
        "address": "127.0.0.1:8088",
        "__settings__": {
          "node_name": "httpserver",
          "ref_logger": "httpserver_log",
          "mongo_id_list":{
            "slg_db":"slg_db"
          }
        },
        "enable": true
      }
    ],
    "4": [
      {
        "address": "127.0.0.1",
        "__settings__": {
          "node_name": "gateserver",
          "ref_logger": "gateserver_log"
        },
        "enable": true
      }
    ],
    "5": [
      {
        "address": "",
        "__settings__": {
          "node_name": "slgserver",
          "ref_logger": "slgserver_log",
          "mongo_id_list":{
            "slg_db":"slg_db"
          }
        },
        "enable": true
      }
    ],
    "6": [
      {
        "address": "",
        "__settings__": {
          "node_name": "chatserver",
          "ref_logger": "chatserver_log"
        },
        "enable": true
      }
    ]
    
  },
  "logger": {
    "mastersvr_log": {
      "level": "debug",
      "enable_console": false,
      "enable_write_file": true
    },
    "loginserver_log": {
      "level": "debug",
      "enable_console": false,
      "enable_write_file": true
    },
    "httpserver_log": {
      "level": "debug",
      "enable_console": false,
      "enable_write_file": true
    },
    "gateserver_log": {
      "level": "debug",
      "enable_console": false,
      "enable_write_file": true
    },
    "slgserver_log": {
      "level": "debug",
      "enable_console": false,
      "enable_write_file": true
    },
    "chatserver_log": {
      "level": "debug",
      "enable_console": false,
      "enable_write_file": true
    }
  },
  "data_config": {
    "parser": "json",
    "data_source": "file",
    "file": {
      "file_path": "data/",
      "ext_name": ".json",
      "reload_time": 3000
    },
    "redis": {
      "prefix_key": "data_config",
      "subscribe_key": "data_config_change",
      "address": "127.0.0.1:6379",
      "password": "actorgo2026",
      "db": 0,
      "pool_size": 300,
      "min_idle_conns": 50
    }
  },
  "mongo": {
    "group1": [
      {
        "enable": true,
        "db_id": "slg_db",
        "db_name": "slg_db",
        "uri": "mongodb://127.0.0.1:27017",
        "timeout": 10
      }
    ]
  }
}